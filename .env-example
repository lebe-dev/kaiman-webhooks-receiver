BIND_ADDRESS=0.0.0.0:8080
LOG_LEVEL=info
LOG_TARGET=stdout
DATA_PATH=./data
DATABASE_URL=sqlite://./data/kwp.db?mode=rwc

# Path to config file (default: config.yml)
CONFIG_FILE=config.yml

# Global default body size limit in bytes (default: 262144 = 256 KB, max: 104857600 = 100 MB)
# Can be overridden per channel via max-body-size in config.yml
# DEFAULT_BODY_LIMIT=262144
